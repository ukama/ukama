# Copy to .env.local and adjust per environment.
# Blank values fall back to the defaults in src/env.ts.

# API gateway (GraphQL) — console-bff
NEXT_PUBLIC_API_GW=http://localhost:8080

# Auth/session gateway (/get-user token exchange) — usually same as API_GW
NEXT_PUBLIC_API_GW_4SS=http://localhost:8080

# Auth app — redirect target when ukama_session/token cookies are missing
# (src/proxy.ts sends users to ${NEXT_PUBLIC_AUTH_APP_URL}/auth/login)
NEXT_PUBLIC_AUTH_APP_URL=http://localhost:4455

# Metrics endpoint (polled range metrics)
NEXT_PUBLIC_METRIC_URL=http://localhost:8081
